# Public branding
NEXT_PUBLIC_APP_NAME="SKWER MKT"
NEXT_PUBLIC_APP_SHORT_NAME="SKWER"
NEXT_PUBLIC_APP_TAGLINE="One buyer can bring the next."
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"
NEXT_PUBLIC_SUPPORT_PHONE=""

# Supabase (publishable values are client-visible; service role is secret)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Paystack — use test keys locally
PAYSTACK_SECRET_KEY="sk_test_replace_me"
PAYSTACK_WEBHOOK_SECRET="sk_test_replace_me"

# Generate independent random values of at least 32 bytes
ORDER_TOKEN_SECRET="replace-with-a-random-32-byte-secret"
REFERRAL_TOKEN_SECRET="replace-with-a-different-random-32-byte-secret"
CRON_SECRET="replace-with-a-random-32-byte-secret"

# Hosted transactional email service
EMAIL_SERVICE_URL="https://send-email-three-lake.vercel.app/api/send"
EMAIL_SERVICE_SECRET="replace-with-email-service-secret"

# Media provider: supabase | cloudinary
MEDIA_PROVIDER="supabase"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

NGROK_AUTH_TOKEN="replace-with-your-ngrok-auth-token"

# Email delivery: emailjs | vercel. The selected provider is tried first, then the other configured provider.
EMAILJS_SERVICE_ID="replace-with-your-emailjs-service-id"
EMAILJS_TEMPLATE_ID="replace-with-your-emailjs-template-id"
EMAILJS_PUBLIC_KEY="replace-with-your-emailjs-public-key"
EMAILJS_PRIVATE_KEY="replace-with-your-emailjs-private-key"

EMAIL_PROVIDER="emailjs" #vercel

# Launch gates — keep payments off until provider/compliance approval
PAYMENTS_ENABLED="false"
PAYSTACK_SPLIT_ENABLED="false"
SELLER_SIGNUP_MODE="invite_only"
REWARDS_ENABLED="true"
DEPOSITS_ENABLED="true"
RESTOCK_REQUESTS_ENABLED="true"
